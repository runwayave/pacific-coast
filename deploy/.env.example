# atlantis self-host — environment template.
#
# Copy to `.env` at the repo root, fill PG_PASSWORD and CONSOLE_SESSION_SECRET,
# then bring up the stack:
#
#   cp deploy/.env.example .env
#   docker compose -f docker-compose.self-host.yml up -d
#
# Everything below `Required` is optional; the commented value is the default.
# Uncomment and override the ones you want to change.
#
# Two prefixes appear below:
#   ATLANTIS_*  compose-orchestration knobs (image tags, host port mappings,
#               cert-init domain). Read by docker-compose and the cert init
#               script — never by the atlantis-server binary.
#   ATL_*       atlantis-server runtime knobs read by the binary itself.
#
# See docs/reference/configuration.md for the full semantics of every variable.

# ── Deployment mode ───────────────────────────────────────────────────────────
#
# atlantis self-host has two modes:
#
#   bundled (default) — docker compose runs Postgres + memcached + atlantis +
#     console + signer in one stack. Set PG_PASSWORD below; everything else
#     is constructed for you.
#
#   BYO Postgres + memcached — you point atlantis at your own Postgres and
#     memcached (managed services or self-hosted elsewhere). The bundle still
#     starts atlantis + console + signer + cert init. To use this mode:
#       1. Comment out the COMPOSE_PROFILES line below (or set it empty).
#       2. Uncomment PG_URL and MEMCACHED_ADDR under "BYO Postgres + memcached"
#          and point them at your own services.
#       3. Make sure the role / database / extensions exist on your Postgres
#          (see docs/guides/deploy-to-production.md step 1).
#       4. PG_PASSWORD becomes optional in BYO mode (the URL embeds creds).
#       5. Network reachability is on you — atlantis runs in a Docker
#          bridge network; your Postgres / memcached must be reachable from
#          inside that network (host.docker.internal, host-bridged port, VPN,
#          managed-service endpoint, etc.).
#
# COMPOSE_PROFILES is the docker compose variable that activates profiled
# services. The bundled Postgres and memcached are gated behind the
# `bundled` profile; activate it here for bundle mode.
COMPOSE_PROFILES=bundled

# ── Required ──────────────────────────────────────────────────────────────────

# Postgres password for the `atlantis` role. Required in bundled mode;
# optional in BYO mode (the URL you set below embeds the credentials).
# Shared by atlantis-server, signer, and console — rotate all three
# together. The literal `changeme` is accepted by Postgres, so do not
# expose port 5432 before setting this.
PG_PASSWORD=changeme

# HMAC key for console session cookies. The console refuses to start with
# a value under 32 characters, so the literal `changeme` placeholder
# triggers a fatal startup error — set this before the first `up -d`.
# Generate: openssl rand -hex 32
CONSOLE_SESSION_SECRET=changeme

# ── BYO Postgres + memcached ──────────────────────────────────────────────────
#
# Uncomment when running in BYO mode (no bundled Postgres / memcached).
# When unset, the bundled hostnames `postgres:5432` and `memcached:11211`
# are used inside the Docker network.

# Full Postgres URL for the atlantis server. Replaces the bundle's
# constructed `postgres://atlantis:${PG_PASSWORD}@postgres:5432/atlantis`
# default. Signer + console default to this same URL.
# PG_URL=postgres://atlantis:secret@db.internal:5432/atlantis?sslmode=require

# Override only if the console needs a different connection than the
# server (separate role, separate pool, etc.). Otherwise CONSOLE_PG_URL
# defaults to PG_URL automatically.
# CONSOLE_PG_URL=postgres://atlantis_console:secret@db.internal:5432/atlantis?sslmode=require

# Memcached address. Comma-separated for multiple nodes.
# MEMCACHED_ADDR=memcache-0.internal:11211,memcache-1.internal:11211

# ── Postgres (the bundled instance) ───────────────────────────────────────────
# PG_USER=atlantis
# PG_DB=atlantis

# Postgres connection pool, per replica. The bundled console connects to
# the same DB, so budget at least 10 conns for it plus admin sessions.
# Stock Postgres caps at `max_connections=100`; >1 atlantis replica needs
# `PG_MAX_CONNS` lowered or Postgres `max_connections` raised.
# PG_MAX_CONNS=50
# PG_MIN_CONNS=10
# PG_MAX_CONN_IDLE=5m
# PG_MAX_CONN_LIFETIME=1h
# PG_HEALTHCHECK_PERIOD=30s

# Per-query deadline enforced via Go context. When the deadline fires,
# pgx aborts the in-flight query. Lower bound: a runaway query won't
# pin a pool conn longer than this; upper bound: legitimately slow
# analytical reads will be cut short.
# PG_QUERY_TIMEOUT_DEFAULT=2s

# ── Atlantis server ───────────────────────────────────────────────────────────

# Container image. Build locally with: make image
# ATLANTIS_IMAGE=atlantis:local

# Host ports exposed by the atlantis container.
# ATLANTIS_GRPC_PORT=9090
# ATLANTIS_HEALTH_PORT=8081

# Log level: debug | info | warn | error.
# LOG_LEVEL=info

# Run infra + entity migrations on boot. Safe for the single-replica
# bundle. If you ever run >1 atlantis replica, set this to false and
# run migrations from your deploy pipeline — golang-migrate serializes
# on a Postgres advisory lock, but the loser will crash-loop until the
# leader finishes.
#   docker compose -f docker-compose.self-host.yml run atlantis tidectl migrate-up
# SELF_HOST_AUTO_MIGRATE=true

# ── Schema mutation gates ─────────────────────────────────────────────────────

# When true, any authenticated caller can `tide apply` to its own
# namespace. mTLS pins each caller to its cert CN (req.Caller must match)
# and the diff classifier refuses changes that would break another
# caller's schema.
#
# Set false only when a regulator requires literal SQL review on a
# deployment-repo PR before any database change (SOX, HIPAA, PCI). False
# rejects every `tide apply` mutation; schema changes then route through
# `tidectl plan` + `tidectl approve` in the deployment repo.
# ATL_ALLOW_APPLY_MUTATION=true

# Per-CN mutation allowlist. Comma-separated cert common-names that may
# invoke schema-mutating RPCs. Even when on this list, a caller can only
# mutate its OWN namespace — req.Caller must match the connecting cert CN,
# so a leaked cert can't push schema as another caller.
# ATL_MUTATION_ALLOWED_CALLERS=ci-backend,ci-vendor

# Per-CN operator allowlist. Cert CNs permitted to call operator-only RPCs
# (RevokeCaller, RollbackSchema, AdoptBaseline). The bundle defaults this
# to `atlantis-console` (the console BFF's CN) so operator actions from
# the console work without an extra env step; non-bundle deployments
# fall back to ATL_ALLOW_APPLY_MUTATION when unset.
# ATL_OPERATOR_ALLOWED_CALLERS=atlantis-console

# Dev-only: writes each accepted `.atl` submission to disk for a local
# file watcher. Default `false`. Keep false in production — a writable
# mirror directory in the server container is a footgun.
# ATL_MIRROR_SCHEMA=false

# ── Cache (memcached + LRU) ───────────────────────────────────────────────────

# Process-wide tier-0 LRU shared across every entity (keys are
# `entity/id`). Sits in front of memcached; bypasses the network on hot
# keys. Total memory ≈ CACHE_LRU_SIZE × avg row size.
# CACHE_LRU_SIZE=1024

# ── Outbox worker ─────────────────────────────────────────────────────────────

# Cache-invalidation outbox. The SELECT uses `FOR UPDATE SKIP LOCKED`, so
# workers in multiple atlantis replicas coexist safely — the bundle is
# single-replica by deploy convention, not by worker correctness.
# OUTBOX_BATCH_SIZE=100
# OUTBOX_DRAIN_INTERVAL=250ms

# Lag threshold: the worker emits a WARN log line when the oldest
# unprocessed row is older than this. The `atlantis_outbox_lag_seconds`
# Prometheus gauge exposes the live value for your alerting.
# OUTBOX_ALERT_LAG=5m

# TTL on body-cache pointer keys in memcached. Must exceed the longest
# reasonable read latency under load; an expired pointer forces the next
# reader to refetch from Postgres.
# OUTBOX_POINTER_TTL=24h

# ── Rate limits ───────────────────────────────────────────────────────────────

# Per-caller token-bucket. Applies to any caller without a
# RATE_LIMIT_PER_CALLER entry. QPS is the refill rate; BURST is the
# maximum bucket capacity (the largest instantaneous burst of requests
# allowed before throttling). A caller out of tokens gets
# `RESOURCE_EXHAUSTED`.
# RATE_LIMIT_DEFAULT_QPS=1000
# RATE_LIMIT_BURST=200

# Pool saturation cutoff [0..1]. When pgxpool's `AcquiredConns/MaxConns`
# ratio crosses this, the server starts shedding low-priority RPCs with
# `RESOURCE_EXHAUSTED` to protect Postgres. "Low-priority" is hard-coded
# as RPC methods whose name starts with `List` or `Search`; CRUD and Get
# never shed via this gate. Set to 0 to disable shedding entirely.
# RATE_LIMIT_SATURATION_CUTOFF=0.80

# Per-CN rate-limit overrides. Format: "cn=qps,cn=qps". The bundle seeds
# this with `atlantis-console=${CONSOLE_RATE_LIMIT_QPS}` because the
# console fans out many admin reads per SPA page. Setting this var
# replaces the bundled default entirely — re-list the console if you
# want to keep its higher limit.
# Example:
#   RATE_LIMIT_PER_CALLER=atlantis-console=5000,ci-backend=2000

# QPS budget for the console's mTLS client (CN=atlantis-console). Split
# out as its own var so the bundle can ship a console-friendly default
# without forcing operators to retype the full caller list. Ignored if
# RATE_LIMIT_PER_CALLER is set above.
# CONSOLE_RATE_LIMIT_QPS=5000

# ── Observability ─────────────────────────────────────────────────────────────

# OTLP gRPC collector endpoint (e.g. host:4317). Empty disables OTel
# export; the server still emits Prometheus metrics and structured logs.
# OTEL_EXPORTER_OTLP_ENDPOINT=

# ── TLS (custom domain or bring-your-own certs) ──────────────────────────────

# Hostname your atlantis server is reachable by (beyond 'atlantis' and
# 'localhost'). The auto-generated server cert will include
# DNS:<ATLANTIS_DOMAIN> in its SAN list.
# ATLANTIS_DOMAIN=atlantis.example.com

# To use your own CA and certs instead of the auto-generated ones, stop
# the stack, copy your files into the atl-certs Docker volume:
#   ca.crt, server.crt, server.key, console.crt, console.key
# then restart. The init-certs.sh script exits without overwriting if all
# five files are present.

# ── Console ───────────────────────────────────────────────────────────────────
# CONSOLE_IMAGE=atlantis-console:local
# CONSOLE_PORT=3000

# Set the `Secure` flag on session cookies (cookies sent over HTTPS
# only). Default false so `http://localhost` works for first boot. Set
# true once a TLS terminator (reverse proxy, load balancer) sits in
# front — otherwise cookies leak over plaintext on production hostnames.
# CONSOLE_COOKIE_SECURE=false

# How long operator-action audit rows are retained before their monthly
# partition is DROPped. 365 covers the typical SOC 2 audit window and
# PCI DSS §10.5.1's 12-month online minimum (PCI also expects 3 months
# 'immediately available' — partition-drop satisfies that). HIPAA is 6
# years (2190); SOX is 7 years (2555). 0 disables retention (partitions
# are still created monthly, but never dropped).
# CONSOLE_AUDIT_RETENTION_DAYS=365

# Sandbox per-user concurrency cap. A user already at the cap requesting a
# new sandbox gets HTTP 429.
# SANDBOX_PER_USER_LIMIT=3

# Sandbox idle TTL. The BFF janitor evicts sandboxes whose last request
# is older than this. Go duration syntax (10s, 30m, 2h).
# SANDBOX_TTL=30m

# ── Signer ────────────────────────────────────────────────────────────────────
# SIGNER_IMAGE=atlantis-signer:local
# SIGNER_PORT=7071

# ── GitHub integration (optional) ─────────────────────────────────────────────

# Fine-grained PAT with contents:write + pull_requests:write on each
# caller repo. Leave unset to disable the "Open PR" button on the
# console's Schema page (preview still works).
# GITHUB_TOKEN=github_pat_...
