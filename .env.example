# atlantis — environment template
# Copy to .env and edit for local development.

# gRPC server bind
GRPC_LISTEN=:9090

# Postgres
PG_URL=postgres://atlantis:atlantis@localhost:5432/atlantis?sslmode=disable
PG_MAX_CONNS=50
PG_MIN_CONNS=10
PG_MAX_CONN_IDLE=5m
PG_MAX_CONN_LIFETIME=1h
PG_HEALTHCHECK_PERIOD=30s
PG_QUERY_TIMEOUT_DEFAULT=2s

# Memcached addresses (comma-separated for sharding)
MEMCACHED_ADDR=localhost:11211

# Cache tier-0 LRU
CACHE_LRU_SIZE=1024

# Observability
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=

# mTLS material (for non-local deploys)
TLS_CERT_FILE=
TLS_KEY_FILE=
TLS_CA_FILE=

# Outbox worker
OUTBOX_BATCH_SIZE=100
OUTBOX_DRAIN_INTERVAL=250ms
OUTBOX_ALERT_LAG=5m

# Per-caller rate limits. RATE_LIMIT_PER_CALLER format: "caller=qps,caller=qps".
RATE_LIMIT_DEFAULT_QPS=1000
RATE_LIMIT_BURST=200
RATE_LIMIT_PER_CALLER=
RATE_LIMIT_SATURATION_CUTOFF=0.80

# Apply infra + tidectl migrations on server boot. Default off here so
# local-dev iterations don't auto-migrate against a shared DB; the
# self-host bundle sets SELF_HOST_AUTO_MIGRATE=true by default (see
# deploy/.env.example) because it's single-replica.
AUTO_MIGRATE=false
MIGRATIONS_DIR=migrations
